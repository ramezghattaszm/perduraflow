# apps/api — NestJS server environment (Zod-validated at startup; see src/config/env.ts)

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/perduraflow   # required

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=dev-access-secret-change-me-min-32-characters-long     # required (min 32)
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-min-32-characters-long   # required (min 32)
JWT_ACCESS_EXPIRES_IN=15m                            # optional (default 15m)
JWT_REFRESH_EXPIRES_IN=90d                           # optional (default 90d)

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000                                            # optional (default 3000)
NODE_ENV=development                                 # development|test|production
CORS_ORIGIN=http://localhost:3001                    # optional (csv; default localhost:3001)

# ─── Email (provider selected by EMAIL_PROVIDER) ─────────────────────────────
EMAIL_PROVIDER=console                               # 'console' | 'smtp' (default console)
EMAIL_FROM=noreply@perduraflow.app                  # sender address
SMTP_HOST=smtp.example.com                            # required when EMAIL_PROVIDER=smtp
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=change-me

# ─── Storage (provider selected by STORAGE_PROVIDER) ─────────────────────────
STORAGE_PROVIDER=local                               # 'local' | 's3' (default local)
LOCAL_STORAGE_PATH=./uploads
LOCAL_STORAGE_URL=http://localhost:3000/uploads
# AWS S3 (required when STORAGE_PROVIDER=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=perduraflow-uploads
