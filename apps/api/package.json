    "db:migrate:custom": "tsx src/db/migrate-custom.ts",
    "db:seed": "tsx src/db/seed.ts",
    "demo:reset": "tsx src/db/reset.ts",
    "plan:baseline": "tsx src/db/plan-baseline.ts",
    "objective:baseline": "tsx src/db/objective-baseline.ts",
    "comparative:baseline": "tsx src/db/comparative-baseline.ts"
  },
  "dependencies": {
    "@perduraflow/contracts": "0.0.1",
    "@aws-sdk/client-s3": "^3.726.1",
    "@aws-sdk/s3-request-presigner": "^3.726.1",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/event-emitter": "^2.1.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/throttler": "^6.3.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
