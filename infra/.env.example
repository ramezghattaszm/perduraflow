# Perdura demo — instance .env TEMPLATE.
# Copy to `.env` ON THE INSTANCE ONLY, fill in, chmod 600. NEVER commit the real file.
# (Purpose-built for prod — NOT a copy of apps/api/.env. See the deploy plan.)

# ─── Image source (from build-and-push.sh / your ECR) ────────────────────────
ECR_REGISTRY=<acct-id>.dkr.ecr.us-east-1.amazonaws.com
IMAGE_TAG=latest

# ─── Postgres (container) ────────────────────────────────────────────────────
POSTGRES_USER=perdura
POSTGRES_PASSWORD=<generate a strong password>
POSTGRES_DB=perdura

# ─── API runtime (Zod-validated at startup; apps/api/src/config/env.ts) ───────
# DATABASE_URL points at the compose `db` service (NOT an external host).
DATABASE_URL=postgresql://perdura:<same POSTGRES_PASSWORD>@db:5432/perdura
NODE_ENV=production
PORT=3010
CORS_ORIGIN=https://perdura.thezmgroup.com

# Fresh secrets for prod — ≥32 chars each. Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=<fresh ≥32 chars>
JWT_REFRESH_SECRET=<fresh ≥32 chars>
# TTLs — defaults are fine; uncomment to override.
# JWT_ACCESS_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=90d

# ─── LLM (same as dev: Groq) ─────────────────────────────────────────────────
LLM_PROVIDER=groq
GROQ_API_KEY=<dev Groq key>
LLM_MODEL=llama-3.3-70b-versatile

# ─── Providers left on safe defaults (no secrets needed for the demo) ─────────
EMAIL_PROVIDER=console
STORAGE_PROVIDER=local
