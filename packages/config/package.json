    "@tamagui/font-inter": "2.0.0-rc.16",
    "@tamagui/shorthands": "2.0.0-rc.16",
    "@tamagui/themes": "2.0.0-rc.16",
    "tamagui": "2.0.0-rc.16"
  },
  "devDependencies": {
    "@tamagui/build": "2.0.0-rc.16"
  }
}
